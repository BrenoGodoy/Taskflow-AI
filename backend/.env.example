# Conexão com o PostgreSQL
# Local: localhost | Docker Compose: postgres | Railway: use a variável gerada pelo plugin Postgres
DATABASE_URL="postgresql://taskflow:taskflow@localhost:5432/taskflow?schema=public"

# Porta da API (Railway injeta PORT automaticamente — não precisa alterar lá)
PORT=3000

# Ambiente
NODE_ENV=development

# ====== CORS (produção — Railway) ======
# URL do frontend na Vercel (sem barra final)
FRONTEND_URL=https://seu-app.vercel.app

# Origens extras separadas por vírgula (preview branches, domínio customizado)
# CORS_ORIGINS=https://seu-app.vercel.app,https://www.seudominio.com

# Permite qualquer subdomínio *.vercel.app (útil para preview deploys). Padrão: true em produção
CORS_ALLOW_VERCEL=true
