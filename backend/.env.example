# Conexão com o PostgreSQL
# Local: localhost | Docker Compose: postgres | Railway: use a variável gerada pelo plugin Postgres
DATABASE_URL="postgresql://taskflow:taskflow@localhost:5432/taskflow?schema=public"

# Porta da API (Railway injeta PORT automaticamente — não precisa alterar lá)
PORT=3000

# Ambiente
NODE_ENV=development

# ===== Modo demo isolado por visitante =====
# Tempo de vida (horas) de cada sessão demo antes de expirar e ser limpa.
DEMO_SESSION_TTL_HOURS=24

# (Opcional) Protege o endpoint DELETE /api/demo/cleanup.
# Se definido, é exigido o header X-Admin-Secret com este valor.
ADMIN_RESET_SECRET=
